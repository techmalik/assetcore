# AssetCore backoffice (admin.assetcore.com) — Supabase connection.
# Copy to apps/admin/.env and fill from your Supabase project:
#   Dashboard → Project Settings → API
# Only the ANON (public) key belongs here. NEVER put the service_role key in any
# frontend — the admin-api Edge Function holds it server-side.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: override the admin-api Edge Function base URL.
# Defaults to ${VITE_SUPABASE_URL}/functions/v1/admin-api
VITE_ADMIN_API_URL=
