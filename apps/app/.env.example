# AssetCore product app. Defaults to same-origin /api — no vars are required
# for local dev (Vite proxies /api to apps/api, see vite.config.js) or for a
# same-origin production deploy (nginx proxies /api — see deploy/nginx.conf).
# Only set VITE_API_URL for a split-host setup where the API lives elsewhere.
VITE_API_URL=

# Per-client branding, baked in at build time (see scripts/package.mjs).
VITE_INSTANCE_NAME=
VITE_INSTANCE_CLIENT=
VITE_SUPPORT_EMAIL=
