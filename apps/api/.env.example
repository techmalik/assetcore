# AssetCore API — plain PostgreSQL connection.
# Copy to apps/api/.env and fill in for your local Postgres.

# RLS-enforced pool: the API's normal request path connects as this
# non-owner role, so every query is subject to row-level security.
DATABASE_URL=postgres://assetcore_app:assetcore_app@localhost:5432/assetcore

# Owner-role pool: bypasses RLS. Used ONLY for auth (pre-session user lookup,
# token issuance), /api/admin + /api/org privileged writes, and node-cron jobs
# — the same narrow set of privileged surfaces the old service_role covered.
# Also used by scripts/migrate.mjs and scripts/seed-dev.mjs.
DATABASE_URL_OWNER=postgres://postgres:postgres@localhost:5432/assetcore

PORT=8787
APP_ORIGIN=http://localhost:5174

JWT_SECRET=dev-only-change-me
JWT_ACCESS_TTL=60m

FILES_DIR=./data/files
LOGS_DIR=./data/logs

TZ=Africa/Lagos

# SMTP — leave blank in dev to print emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AssetCore <no-reply@assetcore.local>
