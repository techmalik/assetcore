# Copy to deploy/.env.deploy and fill in for this client's instance.
# Used by: docker compose -f deploy/docker-compose.yml --env-file deploy/.env.deploy ...
# Generate secrets with: openssl rand -hex 32

# Postgres superuser password (owner role — migrations, provisioning, cron jobs).
# NOTE: docker compose does NOT expand ${VARS} written inside this file, so
# paste the same password literally into both POSTGRES_PASSWORD and the
# DATABASE_URL_OWNER connection string below — they must match.
POSTGRES_PASSWORD=

# assetcore_app's password is set by db/migrations/0001_baseline.sql to the
# literal 'assetcore_app' — ROTATE IT after migrating (see docs/DEPLOYMENT.md
# step "Rotate the app role password") and put the new value into both the
# role and DATABASE_URL below; they must match.
DATABASE_URL=postgres://assetcore_app:assetcore_app@postgres:5432/assetcore
DATABASE_URL_OWNER=postgres://postgres:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/assetcore

# Public origin this instance is served at (informational — CORS is disabled
# in production since nginx proxies same-origin; still validated as non-empty)
APP_ORIGIN=https://assetcore.client.example

JWT_SECRET=
JWT_ACCESS_TTL=60m

TZ=Africa/Lagos
HTTP_PORT=80

# SMTP relay for password reset / invite emails. Leave blank to have the API
# print emails to its container logs instead of sending (not for production).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AssetCore <no-reply@assetcore.local>

# Per-client branding, baked into the SPA bundles when `npm run package`
# builds them (see scripts/package.mjs) — not read at container runtime.
# Export these before running `npm run package` to rebrand; a re-deploy of
# the resulting tarball is required, a container restart is not enough.
VITE_INSTANCE_NAME=AssetCore
VITE_INSTANCE_CLIENT=
VITE_SUPPORT_EMAIL=support@assetcore.io
